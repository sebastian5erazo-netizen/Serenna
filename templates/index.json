      "settings": {
        "custom_liquid": "{%- comment -%}\n  SERENNA · Reseñas (foto, video y nota de voz de WhatsApp)\n  PEGAR EN: editor de temas › sección/bloque \"Liquid personalizado\" (Custom Liquid)\n  IMPORTANTE: debe estar en una página de PRODUCTO.\n  Lee de: product.metafields.custom.resenas  (lista de metaobjetos \"Reseña\")\n  Para cambiar colores/título: edita el bloque #srv-serenna { ... } y el <h2> de abajo.\n{%- endcomment -%}\n\n{%- assign reviews = product.metafields.custom.resenas.value -%}\n{%- assign total = 0 -%}\n{%- assign sum = 0 -%}\n{%- if reviews -%}\n  {%- for r in reviews -%}\n    {%- assign total = total | plus: 1 -%}\n    {%- assign sum = sum | plus: r.rating.value -%}\n  {%- endfor -%}\n{%- endif -%}\n{%- assign avg = 0 -%}\n{%- if total > 0 -%}\n  {%- assign avg = sum | times: 1.0 | divided_by: total -%}\n{%- endif -%}\n{%- assign avg_round = avg | round -%}\n\n<style>\n  #srv-serenna {\n    --srv-accent: #b76e79;\n    --srv-accent-soft: rgba(183,110,121,.08);\n    --srv-accent-line: rgba(183,110,121,.18);\n    --srv-star: #d4a23a;\n    --srv-card: #ffffff;\n    --srv-text: #2a2326;\n    --srv-muted: rgba(42,35,38,.6);\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 48px 18px;\n    color: var(--srv-text);\n    font-family: inherit;\n    box-sizing: border-box;\n  }\n  #srv-serenna *, #srv-serenna *::before, #srv-serenna *::after { box-sizing: border-box; }\n\n  #srv-serenna .srv__head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 18px; margin-bottom: 22px; }\n  #srv-serenna .srv__title { font-size: clamp(22px, 3vw, 30px); font-weight: 600; letter-spacing: -0.01em; margin: 0; }\n  #srv-serenna .srv__summary { display: inline-flex; align-items: center; gap: 8px; }\n  #srv-serenna .srv__avg { font-size: 22px; font-weight: 700; }\n  #srv-serenna .srv__stars { color: var(--srv-star); font-size: 18px; letter-spacing: 1px; }\n  #srv-serenna .srv__count { color: var(--srv-muted); font-size: 14px; }\n\n  #srv-serenna .srv__filters { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }\n  #srv-serenna .srv__filter {\n    border: 1px solid var(--srv-accent); background: transparent; color: var(--srv-accent);\n    border-radius: 999px; padding: 7px 15px; font-size: 13.5px; cursor: pointer;\n    transition: all .15s ease; font-family: inherit;\n  }\n  #srv-serenna .srv__filter:hover { background: var(--srv-accent-soft); }\n  #srv-serenna .srv__filter.is-active { background: var(--srv-accent); color: #fff; }\n\n  #srv-serenna .srv__grid { display: grid; gap: 18px; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); }\n  #srv-serenna .srv__card {\n    background: var(--srv-card); border-radius: 16px; padding: 18px;\n    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.04);\n    display: flex; flex-direction: column; gap: 12px;\n  }\n  #srv-serenna .srv__card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }\n  #srv-serenna .srv__name { margin: 0; font-weight: 600; font-size: 15.5px; }\n  #srv-serenna .srv__detail { margin: 2px 0 0; font-size: 13px; color: var(--srv-muted); }\n  #srv-serenna .srv__card-stars { color: var(--srv-star); font-size: 15px; white-space: nowrap; letter-spacing: 1px; }\n\n  #srv-serenna .srv__voice {\n    display: flex; align-items: center; gap: 10px;\n    background: var(--srv-accent-soft); border: 1px solid var(--srv-accent-line);\n    border-radius: 12px; padding: 10px 12px;\n  }\n  #srv-serenna .srv__voice-ico { font-size: 18px; }\n  #srv-serenna .srv__audio { flex: 1; height: 38px; min-width: 0; }\n  #srv-serenna .srv__voice-tag {\n    font-size: 11px; font-weight: 600; color: var(--srv-accent);\n    text-transform: uppercase; letter-spacing: .04em; white-space: nowrap;\n  }\n\n  #srv-serenna .srv__text { margin: 0; font-size: 14.5px; line-height: 1.55; }\n  #srv-serenna .srv__photos { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; }\n  #srv-serenna .srv__photo { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; cursor: zoom-in; }\n  #srv-serenna .srv__video video { width: 100%; border-radius: 12px; background: #000; max-height: 360px; }\n  #srv-serenna .srv__date { font-size: 12px; color: var(--srv-muted); margin-top: 2px; }\n  #srv-serenna .srv__empty {\n    text-align: center; color: var(--srv-muted); font-size: 15px;\n    padding: 36px 18px; border: 1px dashed var(--srv-accent-line); border-radius: 14px;\n  }\n</style>\n\n<section id=\"srv-serenna\" class=\"srv\">\n  <div class=\"srv__head\">\n    <h2 class=\"srv__title\">Lo que dicen nuestras clientas</h2>\n    {%- if total > 0 -%}\n      <div class=\"srv__summary\">\n        <span class=\"srv__avg\">{{ avg | round: 1 }}</span>\n        <span class=\"srv__stars\" aria-hidden=\"true\">\n          {%- for i in (1..5) -%}{%- if i <= avg_round -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}\n        </span>\n        <span class=\"srv__count\">{{ total }} reseña{% if total != 1 %}s{% endif %}</span>\n      </div>\n    {%- endif -%}\n  </div>\n\n  {%- if total > 0 -%}\n    <div class=\"srv__filters\">\n      <button class=\"srv__filter is-active\" data-filter=\"all\" type=\"button\">Todas</button>\n      <button class=\"srv__filter\" data-filter=\"audio\" type=\"button\">🎙️ Notas de voz</button>\n      <button class=\"srv__filter\" data-filter=\"photo\" type=\"button\">📷 Con foto</button>\n      <button class=\"srv__filter\" data-filter=\"video\" type=\"button\">🎬 Con video</button>\n    </div>\n\n    <div class=\"srv__grid\">\n      {%- for r in reviews -%}\n        {%- assign has_photo = false -%}\n        {%- if r.photos.value != blank and r.photos.value.size > 0 -%}{%- assign has_photo = true -%}{%- endif -%}\n        {%- assign has_video = false -%}\n        {%- if r.video_url.value != blank -%}{%- assign has_video = true -%}{%- endif -%}\n        {%- assign has_audio = false -%}\n        {%- if r.audio_url.value != blank -%}{%- assign has_audio = true -%}{%- endif -%}\n\n        <article class=\"srv__card\" data-photo=\"{{ has_photo }}\" data-video=\"{{ has_video }}\" data-audio=\"{{ has_audio }}\">\n          <div class=\"srv__card-head\">\n            <div>\n              <p class=\"srv__name\">{{ r.name.value | default: 'Clienta verificada' | escape }}</p>\n              {%- if r.detail.value != blank -%}<p class=\"srv__detail\">{{ r.detail.value | escape }}</p>{%- endif -%}\n            </div>\n            {%- if r.rating.value -%}\n              <div class=\"srv__card-stars\" aria-label=\"{{ r.rating.value }} de 5\">\n                {%- for i in (1..5) -%}{%- if i <= r.rating.value -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}\n              </div>\n            {%- endif -%}\n          </div>\n\n          {%- if has_audio -%}\n            <div class=\"srv__voice\">\n              <span class=\"srv__voice-ico\" aria-hidden=\"true\">🎙️</span>\n              <audio class=\"srv__audio\" controls preload=\"none\" src=\"{{ r.audio_url.value }}\">Tu navegador no soporta audio.</audio>\n              <span class=\"srv__voice-tag\">Nota de voz</span>\n            </div>\n          {%- endif -%}\n\n          {%- if r.text.value != blank -%}<p class=\"srv__text\">{{ r.text.value | newline_to_br }}</p>{%- endif -%}\n\n          {%- if has_photo -%}\n            <div class=\"srv__photos\">\n              {%- for photo in r.photos.value -%}\n                {{ photo | image_url: width: 480 | image_tag: loading: 'lazy', class: 'srv__photo', alt: 'Reseña de clienta' }}\n              {%- endfor -%}\n            </div>\n          {%- endif -%}\n\n          {%- if has_video -%}\n            <div class=\"srv__video\"><video controls preload=\"none\" playsinline src=\"{{ r.video_url.value }}\"></video></div>\n          {%- endif -%}\n\n          {%- if r.date.value -%}<time class=\"srv__date\">{{ r.date.value | date: \"%d/%m/%Y\" }}</time>{%- endif -%}\n        </article>\n      {%- endfor -%}\n    </div>\n  {%- else -%}\n    <p class=\"srv__empty\">Aún no hay reseñas para este producto. ¡Sé la primera en compartir tu experiencia! 💛</p>\n  {%- endif -%}\n</section>\n\n<script>\n  (function () {\n    var root = document.getElementById('srv-serenna');\n    if (!root) return;\n    var filters = root.querySelectorAll('.srv__filter');\n    var cards = root.querySelectorAll('.srv__card');\n    filters.forEach(function (btn) {\n      btn.addEventListener('click', function () {\n        filters.forEach(function (b) { b.classList.remove('is-active'); });\n        btn.classList.add('is-active');\n        var f = btn.getAttribute('data-filter');\n        cards.forEach(function (c) {\n          var show = (f === 'all') || (c.getAttribute('data-' + f) === 'true');\n          c.style.display = show ? '' : 'none';\n        });\n      });\n    });\n  })();\n</script>",
